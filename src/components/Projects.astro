---
import { Image } from 'astro:assets'
import fxChecker from '../assets/fx-checker.jpg'
import healthy from '../assets/healthy.jpg'
import enlamano from '../assets/enlamano.jpg'
import techbookclub from '../assets/techbookclub.jpg'

const list: [string, string, ImageMetadata, string][] = [
  [
    'fx_checker',
    'Aplicación web de conversión de divisas.',
    fxChecker,
    'fx-checker.pages.dev'
  ],
  [
    'healthy',
    'Sitio web de recetas saludables.',
    healthy,
    'healthy-jvm.vercel.app'
  ],
  [
    'en-la-mano',
    'Sitio web para solicitar préstamos en línea.',
    enlamano,
    'enlamano.com.uy'
  ],
  [
    'tech-book-club',
    'Landing page para un club de lectura.',
    techbookclub,
    'techbookclub.pages.dev'
  ]
]
---

<section class="py-24 px-6 sm:px-9 md:px-12">
  <div class="max-w-6xl mx-auto">
    <h2 class="flex items-center gap-9 font-semibold text-2xl md:text-3xl">
      <span>Mis proyectos</span>
      <span class="grow border-t-2 border-dashed border-slate-200"></span>
    </h2>
    <ul class="mt-12 grid gap-9 md:grid-cols-2">
      {
        list.map(([id, description, image, domain]) => (
          <li
            class:list={[
              'pt-9 pl-9 flex flex-col rounded-md shadow-xs bg-slate-300/20',
              'lg:pl-12'
            ]}
          >
            <p class="mr-9 font-medium text-pretty md:text-lg">{description}</p>
            <div class="mt-3 mb-9 flex gap-3 font-semibold text-sm text-white">
              <a
                class="text-blue-600/80 underline-offset-2 hover:underline"
                href={`https://${domain}`}
                target="_blank"
                rel="noreferrer"
              >
                Visitar sitio
              </a>
              <a
                class="text-red-500/80 underline-offset-2 hover:underline"
                href={`https://github.com/jhanca-vm/${id}`}
                target="_blank"
                rel="noreferrer"
              >
                Ver código
              </a>
            </div>
            <Image
              class:list={[
                'mt-auto rounded-tl-md rounded-br-md border-t-2 border-l-2',
                'border-white'
              ]}
              src={image}
              alt=""
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>
